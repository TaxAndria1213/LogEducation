  "scripts": {
    "build": "tsc",
    "dev": "nodemon src/index.ts",
    "start": "node dist/index.js",
    "sysdev": "nodemon --exec ts-node --experimental-specifier-resolution=node src/systemIndex.ts",
    "reload-server": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/index.ts",
    "prisma:concat": "node ./prisma/concat-schemas.js && npx prisma format",
    "prisma:generate": "yarn prisma:concat && npx prisma generate",
    "watch": "ts-node src/index.ts",
    "test": "jest"
  },
