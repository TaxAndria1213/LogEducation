  eleve_id              String
  annee_scolaire_id     String
  facture_id            String?
  plan_paiement_id      String?
  statut                StatutDossierRecouvrement @default(OUVERT)
  motif                 String?
  note                  String?
  montant_reference     Decimal? @db.Decimal(12, 2)
  date_statut           DateTime @default(now())
  cree_par_utilisateur_id String?
  valide_par_utilisateur_id String?
  valide_le             DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  etablissement Etablissement @relation(fields: [etablissement_id], references: [id])
  eleve Eleve @relation(fields: [eleve_id], references: [id])
  annee AnneeScolaire @relation(fields: [annee_scolaire_id], references: [id])
  facture Facture? @relation(fields: [facture_id], references: [id], onDelete: SetNull)
  planPaiement PlanPaiementEleve? @relation(fields: [plan_paiement_id], references: [id], onDelete: SetNull)
  createur Utilisateur? @relation("dossier_recouvrement_createur", fields: [cree_par_utilisateur_id], references: [id])
  validateur Utilisateur? @relation("dossier_recouvrement_validateur", fields: [valide_par_utilisateur_id], references: [id])

  @@index([etablissement_id, statut], map: "idx_dossier_recouvrement_etab_statut")
  @@index([eleve_id, annee_scolaire_id], map: "idx_dossier_recouvrement_eleve_annee")
  @@index([facture_id], map: "idx_dossier_recouvrement_facture")
  @@index([plan_paiement_id], map: "idx_dossier_recouvrement_plan")
  @@map("dossiers_recouvrement")
}

/**
 * =========================
 * 11) BIBLIOTHÃˆQUE
 * =========================
 */
model RessourceBibliotheque {
  id               String  @id @default(uuid())
  etablissement_id String
  type             String // livre/materiel
  titre            String
  code             String?
  auteur           String?
  editeur          String?
  annee            Int?
  stock            Int?    @default(1)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  emprunts Emprunt[]

  @@index([etablissement_id])
  @@map("ressources_bibliotheque")
}

model Emprunt {
  id                        String    @id @default(uuid())
  ressource_bibliotheque_id String
  eleve_id                  String?
  personnel_id              String?
  emprunte_le               DateTime  @default(now())
  du_le                     DateTime?
  retourne_le               DateTime?
  statut                    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  ressource RessourceBibliotheque @relation(fields: [ressource_bibliotheque_id], references: [id])
  eleve     Eleve?                @relation(fields: [eleve_id], references: [id])
  personnel Personnel?            @relation(fields: [personnel_id], references: [id])

  @@index([ressource_bibliotheque_id])
  @@map("emprunts")
}

/**
 * =========================
 * 12) TRANSPORT / CANTINE
 * =========================
 */
model LigneTransport {
  id                  String @id @default(uuid())
  etablissement_id    String
  nom                 String
  catalogue_frais_id  String?
  infos_vehicule_json Json?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  frais       CatalogueFrais? @relation(fields: [catalogue_frais_id], references: [id], onDelete: SetNull)
  arrets      ArretTransport[]
  abonnements AbonnementTransport[]

  @@index([etablissement_id])
  @@index([catalogue_frais_id], map: "idx_lignetransport_frais")
  @@map("lignes_transport")
}

model ArretTransport {
  id                 String @id @default(uuid())
  ligne_transport_id String
  nom                String
  geo_json           Json?
  ordre              Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  ligne               LigneTransport        @relation(fields: [ligne_transport_id], references: [id])
  AbonnementTransport AbonnementTransport[]

  @@index([ligne_transport_id])
  @@map("arrets_transport")
}

model AbonnementTransport {
  id                 String  @id @default(uuid())
  eleve_id           String
  annee_scolaire_id  String
  ligne_transport_id String
  arret_transport_id String?
  facture_id         String?
  statut             String?
  date_debut_service DateTime?
  date_fin_service   DateTime?
  prorata_ratio      Decimal? @db.Decimal(8, 4)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  eleve Eleve           @relation(fields: [eleve_id], references: [id])
  annee AnneeScolaire   @relation(fields: [annee_scolaire_id], references: [id])
  ligne LigneTransport  @relation(fields: [ligne_transport_id], references: [id])
  arret ArretTransport? @relation(fields: [arret_transport_id], references: [id])
  facture Facture?      @relation(fields: [facture_id], references: [id], onDelete: SetNull)

  @@index([eleve_id])
  @@index([facture_id], map: "idx_abt_facture")
  @@map("abonnements_transport")
}

model FormuleCantine {
  id               String  @id @default(uuid())
  etablissement_id String
  nom              String
  catalogue_frais_id String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  abonnements AbonnementCantine[]
  frais       CatalogueFrais? @relation(fields: [catalogue_frais_id], references: [id], onDelete: SetNull)

  @@index([etablissement_id])
  @@index([catalogue_frais_id], map: "idx_formulecantine_frais")
  @@map("formules_cantine")
}

model AbonnementCantine {
  id                 String  @id @default(uuid())
  eleve_id           String
  annee_scolaire_id  String
  formule_cantine_id String
  facture_id         String?
  statut             String?
  solde_prepaye      Decimal @default(0) @db.Decimal(12, 2)
  solde_min_alerte   Decimal @default(0) @db.Decimal(12, 2)
  dernier_rechargement_le DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  eleve   Eleve          @relation(fields: [eleve_id], references: [id])
  annee   AnneeScolaire  @relation(fields: [annee_scolaire_id], references: [id])
  formule FormuleCantine @relation(fields: [formule_cantine_id], references: [id])
  facture Facture?       @relation(fields: [facture_id], references: [id], onDelete: SetNull)
  operationsFinancieres OperationFinanciere[]

  @@index([eleve_id])
  @@index([facture_id], map: "idx_abc_facture")
  @@map("abonnements_cantine")
}

/**
 * =========================
 * 13) DOCUMENTS
