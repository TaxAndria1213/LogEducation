 */
model Fichier {
  id                          String   @id @default(uuid())
  etablissement_id            String
  proprietaire_utilisateur_id String?
  fournisseur_stockage        String?
  chemin                      String
  type_mime                   String?
  taille                      Int?
  checksum                    String?
