{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    // "paths": {
    //   "@src/*": ["src/*"],
    // }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "build", ".next", "out", "coverage"],
  "ts-node": {
    "transpileOnly": true
  }
}
